(setq display-time-default-load-average nil
      tab-width 4
      inhibit-splash-screen t)
(global-completion-preview-mode 1)
(display-time-mode 1)
(ido-mode 1)
(ido-everywhere 1)
(custom-set-faces
 '(font-lock-keyword-face ((t (:foreground "#d96bff")))))
(menu-bar-mode 0)
(global-display-line-numbers-mode)
